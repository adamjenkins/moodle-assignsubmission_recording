{{!
    @template assignsubmission_recording/recorder

    RecordRTC recorder used for the recording assignment submission.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * data-region="recording-recorder"
    * data-region="status"
    * data-region="limit-info"
    * data-region="countdown"
    * data-region="preview-wrapper"
    * data-region="preview"
    * data-region="playback"
    * data-action="record-audio"
    * data-action="record-video"
    * data-action="start-recording"
    * data-action="switch-camera"
    * data-action="cancel-preview"
    * data-action="stop"
    * data-action="rerecord"

    Context variables required for this template:
    * allowaudio Boolean Whether an audio recording may be made.
    * allowvideo Boolean Whether a video recording may be made.

    Example context (json):
    {
        "allowaudio": true,
        "allowvideo": true
    }
}}
<div class="assignsubmission-recording-recorder border rounded p-3" data-region="recording-recorder">
    <p class="text-muted" data-region="status">{{#str}} recorderintro, assignsubmission_recording {{/str}}</p>
    <p class="assignsubmission-recording-limit text-muted small mb-2 d-none" data-region="limit-info"></p>
    <p class="assignsubmission-recording-countdown fw-bold mb-2 d-none" data-region="countdown"></p>

    <div class="assignsubmission-recording-preview mb-2 d-none" data-region="preview-wrapper">
        <video class="w-100 rounded" data-region="preview" muted playsinline></video>
    </div>

    <div class="assignsubmission-recording-playback mb-2 d-none" data-region="playback"></div>

    <div class="assignsubmission-recording-controls d-flex flex-wrap gap-2">
        {{#allowaudio}}
            <button type="button" class="btn btn-primary" data-action="record-audio">
                {{#str}} recordaudio, assignsubmission_recording {{/str}}
            </button>
        {{/allowaudio}}
        {{#allowvideo}}
            <button type="button" class="btn btn-primary" data-action="record-video">
                {{#str}} recordvideo, assignsubmission_recording {{/str}}
            </button>
        {{/allowvideo}}
        <button type="button" class="btn btn-success d-none" data-action="start-recording">
            {{#str}} startrecording, assignsubmission_recording {{/str}}
        </button>
        <button type="button" class="btn btn-outline-secondary d-none" data-action="switch-camera">
            {{#str}} switchcamera, assignsubmission_recording {{/str}}
        </button>
        <button type="button" class="btn btn-secondary d-none" data-action="cancel-preview">
            {{#str}} cancelpreview, assignsubmission_recording {{/str}}
        </button>
        <button type="button" class="btn btn-danger d-none" data-action="stop">
            {{#str}} stoprecording, assignsubmission_recording {{/str}}
        </button>
        <button type="button" class="btn btn-secondary d-none" data-action="rerecord">
            {{#str}} rerecord, assignsubmission_recording {{/str}}
        </button>
    </div>
</div>
